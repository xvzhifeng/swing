.test-page {
  flex-direction: column;
  padding: 15px;
  background-color: #000000;
}

.header {
  flex-direction: column;
  margin-bottom: 15px;
}

.back-btn {
  align-self: flex-start;
  padding: 8px 12px;
  margin-bottom: 10px;
}

.back-text {
  font-size: 14px;
  color: #09ba07;
}

.title {
  font-size: 16px;
  color: #ffffff;
  text-align: center;
}

.status {
  font-size: 16px;
  color: #09ba07;
  text-align: center;
  margin-bottom: 20px;
}

.btn {
  height: 45px;
  background-color: #09ba07;
  border-radius: 22px;
  align-items: center;
  justify-content: center;
  margin-bottom: 20px;
}

.btn-text {
  font-size: 16px;
  color: #ffffff;
  font-weight: bold;
}

.tip {
  font-size: 11px;
  color: #999999;
  text-align: center;
  margin-top: 20px;
}
</style>
